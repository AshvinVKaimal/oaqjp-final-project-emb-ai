"""
Server module for the Emotion Detection web application.

This script initializes a Flask server that processes customer feedback text,
analyzes it for emotional sentiment via the EmotionDetection package,
and returns formatted responses to the web interface.
"""

from flask import Flask, render_template, request
from EmotionDetection import emotion_detector

app = Flask(__name__)

@app.route("/emotionDetector")
def emotion_analysis():
    """
    Analyze the incoming text from the user request arguments.

    Retrieves the string parameter 'textToAnalyze', runs the emotion
    detector, handles error validation, and builds a descriptive
    text output of the scores and dominant emotion.
    """
    text = request.args.get('textToAnalyze')
    response = emotion_detector(text)

    if "error" in response:
        return f"Error: {response['error']}"
    if response['dominant_emotion'] is None:
        return "Invalid text! Please try again!"

    anger = response['anger']
    disgust = response['disgust']
    fear = response['fear']
    joy = response['joy']
    sadness = response['sadness']
    dominant_emotion = response['dominant_emotion']

    output = (
        f"For the given statement, the system response is "
        f"'anger': {anger}, 'disgust': {disgust}, 'fear': {fear}, "
        f"'joy': {joy} and 'sadness': {sadness}. "
        f"The dominant emotion is {dominant_emotion}."
    )

    return output

@app.route("/")
def render_index():
    """
    Render the main application interface homepage template.
    """
    return render_template('index.html')

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
